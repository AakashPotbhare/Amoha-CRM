    {
      "name": "🔐 [Auth] Login as Director",
      "event": [{
        "listen": "test",
        "script": { "type": "text/javascript", "exec": [
          "pm.test('Login returns 200', () => pm.response.to.have.status(200));",
          "pm.test('Token returned', () => {",
          "  const json = pm.response.json();",
          "  pm.expect(json.success).to.be.true;",
          "  pm.expect(json.data.token).to.be.a('string').and.have.length.above(20);",
          "  pm.collectionVariables.set('token', json.data.token);",
          "  console.log('✅ Token captured');",
          "});"
        ]}
      }],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": { "mode": "raw", "raw": "{\"employeeCode\":\"DIR001\",\"password\":\"Amoha@2026\"}" }
      }
    },

    {
      "name": "🔐 [Auth] GET /me",
      "event": [{
        "listen": "test",
        "script": { "type": "text/javascript", "exec": [
          "pm.test('Status 200', () => pm.response.to.have.status(200));",
          "pm.test('Returns director profile', () => {",
          "  const d = pm.response.json().data;",
          "  pm.expect(d.role).to.equal('director');",
          "  pm.expect(d).to.have.property('employee_code');",
